# ==========================================
# Live Weather Provider Specs Configuration
# ==========================================
# copy this file to '.env' to run the live integration tests
# live tests are opt-in: they run only when RUN_LIVE=1, and the OWM/WeatherAPI
# tests also need that provider's key below. without RUN_LIVE=1 (or with no
# .env at all) the live tests skip and only the offline unit tests run

# set to 1 to enable live tests for every provider, anything else skips them
RUN_LIVE=1

# OpenWeatherMap (Free Tier)
# get a key at https://openweathermap.org/api
OWM_KEY=

# WeatherAPI (Free Tier)
# get a key at https://www.weatherapi.com/
WEATHERAPI_KEY=

# Open-Meteo (Free)
# no key needed, RUN_LIVE=1 alone enables its live test
