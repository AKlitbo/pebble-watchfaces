# ==========================================
# Live Provider Specs Configuration
# ==========================================
# copy this file to '.env' to run the live integration tests
# live tests are opt-in per domain: the weather tests run only when
# RUN_LIVE_WEATHER=1 and the stock tests only when RUN_LIVE_STOCK=1. each provider's
# live test also needs that provider's key below. with the switch off (or no .env at
# all) the live tests skip and only the offline unit tests run

# set to 1 to enable the weather (and geocoding) live tests, anything else skips them
RUN_LIVE_WEATHER=1

# set to 1 to enable the stock live tests, anything else skips them
RUN_LIVE_STOCK=1

# set to 1 to enable the calendar live test, anything else skips it. also needs CALENDAR_ICS_URL
RUN_LIVE_CALENDAR=1

# your Google Calendar "Secret address in iCal format" (Settings and sharing -> Integrate
# calendar), ending in /basic.ics. treat it like a password
CALENDAR_ICS_URL=

# OpenWeatherMap (Free Tier)
# get a key at https://openweathermap.org/api
OWM_KEY=

# WeatherAPI (Free Tier)
# get a key at https://www.weatherapi.com/
WEATHERAPI_KEY=

# Open-Meteo (Free)
# no key needed, RUN_LIVE_WEATHER=1 alone enables its live test

# Finnhub (Free Tier): real-time US stock quotes, 60 calls/min
# get a key at https://finnhub.io/
FINNHUB_KEY=

# Yahoo (Free): real-time global stock quotes, no key
# no key needed, RUN_LIVE_STOCK=1 alone enables its live test

# Twelve Data (Free Tier): global stock quotes, 800 requests/day
# get a key at https://twelvedata.com/
TWELVEDATA_KEY=

# Alpha Vantage (Free Tier): end-of-day stock quotes, 25 requests/day
# get a key at https://www.alphavantage.co/support/#api-key
ALPHAVANTAGE_KEY=
