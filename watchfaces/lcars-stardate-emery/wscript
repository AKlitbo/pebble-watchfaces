# ==============================================================================
# Waf Build Rules for Pebble Watchface
#
# This script defines the compilation process for the Pebble smartwatch app
# and its background worker. It handles path resolution, source collection
# (C and JavaScript/pkjs) from both local and shared directories, and 
# bundles the final executables for all target platforms.
# ==============================================================================
import os.path
import sys
from waflib.Tools import c_preproc

# let waf's preprocessor scanner trace through absolute include paths (the shared
# lib/ lives two levels up) so it discovers the transitive pebble.h include and
# the SDK can inject the resource_ids.auto.h dependency before compilation starts
c_preproc.go_absolute = True

top = '.'
out = 'build'


def options(ctx):
    ctx.load('pebble_sdk')


def configure(ctx):
    ctx.load('pebble_sdk')


def build(ctx):
    ctx.load('pebble_sdk')

    # --- Path Resolution ---
    # lib = all code shared by ALL watchfaces, two levels up at the repo root
    # (watchfaces/<face>/ -> repo). lib/c/ is pure (SDK-free, host-testable);
    # lib/c/pebble/ needs the SDK; lib/js/ is PebbleKit JS.
    lib_dir = ctx.path.parent.parent.find_dir('lib')
    if not lib_dir:
        ctx.fatal('Could not find the "lib" directory two levels up.')
    lib_c = lib_dir.find_dir('c')
    lib_c_pebble = lib_c.find_dir('pebble')
    lib_js = lib_dir.find_dir('js')
    # this face's own sources, including the LCARS skin code (in widgets.c)
    local_c = ctx.path.find_dir('src/c')

    # --- Source & Include Collection ---
    include_paths = [
        lib_c.abspath(),
        lib_c.find_dir('clock').abspath(),
        lib_c.find_dir('units').abspath(),
        lib_c.find_dir('text').abspath(),
        lib_c_pebble.abspath(),
        lib_c_pebble.find_dir('appmessage').abspath(),
        lib_c_pebble.find_dir('settings').abspath(),
        lib_c_pebble.find_dir('weather').abspath(),
        lib_c_pebble.find_dir('units').abspath(),
        lib_c_pebble.find_dir('health').abspath(),
        lib_c_pebble.find_dir('shell').abspath(),
        lib_c_pebble.find_dir('ui').abspath(),
        local_c.abspath()
    ]

    # src/c/ holds this face's sources (including the LCARS skin in widgets.c); one glob
    # recurses into both lib/c/ (pure) and lib/c/pebble/ (SDK)
    c_sources = ctx.path.ant_glob('src/c/**/*.c') + lib_c.ant_glob('**/*.c')

    js_sources = ctx.path.ant_glob(['src/pkjs/**/*.js', 'src/pkjs/**/*.json'])
    if lib_js:
        # exclude *.spec.js - test files, never imported by index.js, not shipped
        js_sources += lib_js.ant_glob('**/*.js', excl=['**/*.spec.js'])

    # --- Platform Build Loop ---
    build_worker = os.path.exists('worker_src')
    binaries = []
    cached_env = ctx.env

    for platform in ctx.env.TARGET_PLATFORMS:
        ctx.env = ctx.all_envs[platform]
        ctx.set_group(ctx.env.PLATFORM_NAME)

        ctx.env.append_value('INCLUDES', include_paths)

        app_elf = '{}/pebble-app.elf'.format(ctx.env.BUILD_DIR)
        
        # build App
        ctx.pbl_build(
            source=c_sources, 
            target=app_elf, 
            bin_type='app'
        )

        binary_info = {'platform': platform, 'app_elf': app_elf}

        # build worker (if applicable)
        if build_worker:
            worker_elf = '{}/pebble-worker.elf'.format(ctx.env.BUILD_DIR)
            ctx.pbl_build(
                source=ctx.path.ant_glob('worker_src/c/**/*.c'),
                target=worker_elf,
                bin_type='worker'
            )
            binary_info['worker_elf'] = worker_elf
            
        binaries.append(binary_info)

    ctx.env = cached_env

    # --- Bundle Compilation ---
    ctx.set_group('bundle')
    ctx.pbl_bundle(
        binaries=binaries,
        js=js_sources,
        js_entry_file='src/pkjs/index.js'
    )

    # load shared waf helpers to attach the post-build archiving hook
    lib_path = os.path.join(ctx.path.parent.parent.abspath(), 'lib', 'py')
    if lib_path not in sys.path:
        sys.path.insert(0, lib_path)
    import waf_helpers
    
    ctx.add_post_fun(waf_helpers.copy_current_pbw)