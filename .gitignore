# Pebble / Waf build output
build/
.lock-waf_*

# Waf-compiled resource artifacts (sources are versioned)
*.reso

# staged build folders (sources live under watchfaces/<face>/)
targets/*/package.json
targets/*/tsconfig.pkjs.json
targets/*/wscript
targets/*/src/
targets/*/lib/
targets/*/resources/
targets/*/emit/

# Python
__pycache__/
*.pyc

# Node
node_modules/
npm-debug.log*

# compiled PKJS output (regenerated by build:pkjs from TS source)
/emit/

# editor / OS cruft
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# generated documentation, coverage, and site builds
doxygen
coverage/
site/

# temporary files & local secrets
.tmp
.env
.env.local

# Third-party vendored assets (fonts, icons, templates) - not redistributed.
# Includes the TheLCARS.com template: please go to https://www.thelcars.com/
# to download and support the creator.
vendor/