{
  "compilerOptions": {
    "target": "ES2015",
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true
  },
  "include": ["watchfaces/*/src/pkjs/**/*.ts", "lib/ts/**/*.ts"],
  "exclude": ["node_modules", "targets", "watchfaces/*/src/pkjs/clay/builder/**", "**/*.spec.ts"]
}
